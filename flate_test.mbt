///|
test "status is inspectable" {
  debug_inspect(@flate.Done, content="Done")
  debug_inspect(@flate.NeedMoreInput, content="NeedMoreInput")
  debug_inspect(@flate.NeedMoreOutput, content="NeedMoreOutput")
}

// ---- streaming Inflater::step, stored (type 00) blocks ----

///|
/// A single final stored (uncompressed) DEFLATE block holding "hello".
let hello_stored : Bytes = [
  0x01, 0x05, 0x00, 0xFA, 0xFF, 0x68, 0x65, 0x6C, 0x6C, 0x6F,
]

///|
test "inflate a stored block (one-shot)" {
  assert_eq(@flate.inflate_all(hello_stored), b"hello")
}

///|
test "inflate suspends/resumes across a tiny output buffer" {
  let inf = @flate.Inflater::new()
  let small : FixedArray[Byte] = FixedArray::make(2, b'\x00') // forces NeedMoreOutput
  let collected = Buffer()
  let view = hello_stored[:]
  let mut consumed = 0
  for ;; {
    let status = inf.step(view[consumed:], small.mut_view())
    let used = inf.last_consumed()
    let produced = inf.last_produced()
    for i in 0..<produced {
      collected.write_byte(small[i])
    }
    consumed = consumed + used
    if status is Done {
      break
    }
  }
  assert_eq(collected.to_bytes(), b"hello")
  assert_true(inf.is_finished())
}

// ---- inflate_all: real raw-DEFLATE vectors (generated by zlib) ----

///|
let v_fixed_hello : Bytes = [0xCB, 0x48, 0xCD, 0xC9, 0xC9, 0x07, 0x00]

///|
let v_fixed_aaa : Bytes = [0x4B, 0x4C, 0xC4, 0x07, 0x00]

///|
let v_dynamic_text : Bytes = [
  0xDD, 0xCF, 0xCB, 0x15, 0xC2, 0x20, 0x14, 0x84, 0xE1, 0x56, 0xC6, 0x02, 0xB4, 0x0E,
  0x97, 0x2E, 0xD2, 0x00, 0x24, 0x17, 0x82, 0x02, 0x37, 0xE1, 0x99, 0x50, 0xBD, 0xD7,
  0x2A, 0x72, 0x8E, 0xEB, 0xF9, 0xFE, 0xC5, 0x4C, 0x2B, 0x61, 0xAF, 0x6E, 0xFE, 0x40,
  0x27, 0xEE, 0x11, 0x86, 0x0F, 0xBC, 0x6B, 0xD8, 0x32, 0xB8, 0x51, 0x42, 0x91, 0xD9,
  0xAB, 0x71, 0x62, 0x61, 0xFB, 0xC0, 0xF4, 0xEF, 0xF8, 0xA5, 0xC4, 0x85, 0x13, 0x5A,
  0x50, 0x77, 0x65, 0x85, 0x71, 0x8D, 0x64, 0x1A, 0x14, 0xE1, 0xDD, 0x5E, 0x39, 0x49,
  0x6B, 0xF3, 0xA5, 0xF0, 0xC9, 0x1D, 0x49, 0x0D, 0x4E, 0x5A, 0x8A, 0xFB, 0xEF, 0x8A,
  0x8B, 0x16, 0x26, 0xB1, 0xCD, 0x98, 0x95, 0x60, 0x6A, 0xE4, 0x91, 0xDD, 0x81, 0x4D,
  0x32, 0x5A, 0x60, 0xCF, 0x10, 0x55, 0x2E, 0xF9, 0x76, 0x51, 0xFA, 0x05,
]

///|
/// Stored block: bytes 0x00..0x3B (level-0 zlib, raw).
let v_stored_seq : Bytes = [
  0x01, 0x3C, 0x00, 0xC3, 0xFF, 0x00, 0x01, 0x02, 0x03, 0x04, 0x05, 0x06, 0x07, 0x08,
  0x09, 0x0A, 0x0B, 0x0C, 0x0D, 0x0E, 0x0F, 0x10, 0x11, 0x12, 0x13, 0x14, 0x15, 0x16,
  0x17, 0x18, 0x19, 0x1A, 0x1B, 0x1C, 0x1D, 0x1E, 0x1F, 0x20, 0x21, 0x22, 0x23, 0x24,
  0x25, 0x26, 0x27, 0x28, 0x29, 0x2A, 0x2B, 0x2C, 0x2D, 0x2E, 0x2F, 0x30, 0x31, 0x32,
  0x33, 0x34, 0x35, 0x36, 0x37, 0x38, 0x39, 0x3A, 0x3B,
]

///|
test "inflate fixed-Huffman block" {
  assert_eq(@flate.inflate_all(v_fixed_hello), b"hello")
}

///|
test "inflate fixed-Huffman with back-references" {
  assert_eq(@flate.inflate_all(v_fixed_aaa), b"aaaaaaaaaaaaaaaaaaaaaaaaaaaaaa")
}

///|
test "inflate dynamic-Huffman block (exercises link table)" {
  let out = @flate.inflate_all(v_dynamic_text)
  inspect(out.length(), content="611")
  assert_eq(
    out[0:44].to_owned(),
    b"The quick brown fox jumps over the lazy dog.",
  )
}

///|
test "inflate stored block via inflate_all" {
  let out = @flate.inflate_all(v_stored_seq)
  inspect(out.length(), content="60")
  inspect(out[0].to_int(), content="0")
  inspect(out[59].to_int(), content="59")
}

///|
/// Stream a dynamic-Huffman block through `step`, revealing input 5 bytes at a
/// time and draining a 300-byte output buffer (< 611 decoded), exercising both
/// NeedMoreInput and NeedMoreOutput suspension/resume.
test "Inflater::step streams a dynamic block in small chunks" {
  let comp = v_dynamic_text
  let inf = @flate.Inflater::new()
  let obuf = FixedArray::make(300, b'\x00')
  let result = Buffer()
  let mut consumed = 0
  let mut avail = 0
  for ;; {
    let st = inf.step(comp[consumed:avail], obuf.mut_view())
    let c = inf.last_consumed()
    let p = inf.last_produced()
    for i in 0..<p {
      result.write_byte(obuf[i])
    }
    consumed = consumed + c
    if st is Done {
      break
    }
    if st is NeedMoreInput {
      if avail >= comp.length() {
        fail("unexpected truncation")
      }
      avail = if avail + 5 < comp.length() { avail + 5 } else { comp.length() }
    }
  }
  let out = result.to_bytes()
  inspect(out.length(), content="611")
  assert_eq(
    out[0:44].to_owned(),
    b"The quick brown fox jumps over the lazy dog.",
  )
}

///|
/// Stream a fixed-Huffman block (with back-references) one input byte at a time.
test "Inflater::step streams a fixed block one input byte at a time" {
  let comp = v_fixed_aaa
  let inf = @flate.Inflater::new()
  let obuf = FixedArray::make(300, b'\x00')
  let result = Buffer()
  let mut consumed = 0
  let mut avail = 0
  for ;; {
    let st = inf.step(comp[consumed:avail], obuf.mut_view())
    let c = inf.last_consumed()
    let p = inf.last_produced()
    for i in 0..<p {
      result.write_byte(obuf[i])
    }
    consumed = consumed + c
    if st is Done {
      break
    }
    if st is NeedMoreInput {
      if avail >= comp.length() {
        fail("unexpected truncation")
      }
      avail = avail + 1
    }
  }
  assert_eq(result.to_bytes(), b"aaaaaaaaaaaaaaaaaaaaaaaaaaaaaa")
}

///|
/// Drain a long back-reference (30 'a's, a single match) through a *1-byte*
/// output buffer, forcing the decoder to suspend and resume mid-copy on every
/// byte. This is the case the async `@io.Reader` driver hits with small reads,
/// which the old 258-byte-per-unit output floor would have deadlocked on.
test "Inflater::step makes progress with a 1-byte output buffer" {
  let inf = @flate.Inflater::new()
  let obuf = FixedArray::make(1, b'\x00')
  let result = Buffer()
  let view = v_fixed_aaa[:]
  let mut consumed = 0
  for ;; {
    let st = inf.step(view[consumed:], obuf.mut_view(end=1))
    let c = inf.last_consumed()
    let p = inf.last_produced()
    for i in 0..<p {
      result.write_byte(obuf[i])
    }
    consumed = consumed + c
    if st is Done {
      break
    }
  }
  assert_eq(result.to_bytes(), b"aaaaaaaaaaaaaaaaaaaaaaaaaaaaaa")
  assert_true(inf.is_finished())
}

///|
/// Decode the 611-byte dynamic block into a buffer far smaller than a single
/// 258-byte match, exercising mid-copy suspension plus `out_len` sub-ranging
/// (write into the middle of a larger array).
test "Inflater::step honors a small out_len within a larger buffer" {
  let inf = @flate.Inflater::new()
  let obuf = FixedArray::make(64, b'\x00')
  let result = Buffer()
  let view = v_dynamic_text[:]
  let mut consumed = 0
  for ;; {
    // Write into obuf[8:8+7] only, proving out_off/out_len bound the writes.
    let st = inf.step(view[consumed:], obuf.mut_view(start=8, end=15))
    let c = inf.last_consumed()
    let p = inf.last_produced()
    for i in 8..<(8 + p) {
      result.write_byte(obuf[i])
    }
    consumed = consumed + c
    if st is Done {
      break
    }
  }
  let out = result.to_bytes()
  inspect(out.length(), content="611")
  assert_eq(
    out[0:44].to_owned(),
    b"The quick brown fox jumps over the lazy dog.",
  )
}

// ---- stored fallback + sync flush ----

///|
/// Incompressible (pseudo-random) data must fall back to stored blocks:
/// output ≈ input + ~5 bytes of framing per block, never the ~6% expansion of
/// a forced Huffman path.
test "deflate_all stores incompressible data" {
  let arr : Array[Byte] = []
  let mut x = 0x12345678U
  for _i in 0..<70000 {
    x = x ^ (x << 13)
    x = x ^ (x >> 17)
    x = x ^ (x << 5)
    arr.push((x & 0xFF).reinterpret_as_int().to_byte())
  }
  let src = Bytes::from_array(arr)
  let out = @flate.deflate_all(src)
  // 70000 bytes split into ~16 KB blocks, each falling back to stored at
  // ~5 bytes of framing → at most input + a few dozen bytes.
  assert_true(out.length() <= src.length() + 64)
  assert_eq(@flate.inflate_all(out), src)
}

///|
/// Sync flush: after `action=SyncFlush`, the flushed prefix alone must decode to
/// everything fed so far (byte-aligned via the empty stored block, ending in
/// the zlib `00 00 FF FF` marker), and the stream then continues across the
/// flush point.
test "Deflater sync flush makes the prefix decodable" {
  let part1 = b"first message, sent immediately. "
  let part2 = b"second message follows after the flush point."
  let enc = @flate.Deflater::new()
  let obuf = FixedArray::make(4096, b'\x00')
  let st1 = enc.step(part1[:], obuf.mut_view(), action=SyncFlush)
  let c1 = enc.last_consumed()
  let p1 = enc.last_produced()
  assert_true(st1 is NeedMoreInput)
  assert_eq(c1, part1.length())
  // zlib sync-flush signature: the flushed bytes end with 00 00 FF FF.
  assert_true(p1 >= 4)
  assert_eq(obuf[p1 - 4], b'\x00')
  assert_eq(obuf[p1 - 3], b'\x00')
  assert_eq(obuf[p1 - 2], b'\xFF')
  assert_eq(obuf[p1 - 1], b'\xFF')
  // Repeating the same request without new input is idempotent.
  let repeat_status = enc.step(b""[:], obuf.mut_view(), action=SyncFlush)
  let repeat_consumed = enc.last_consumed()
  let repeat_produced = enc.last_produced()
  assert_true(repeat_status is NeedMoreInput)
  assert_eq(repeat_consumed, 0)
  assert_eq(repeat_produced, 0)
  // The prefix alone already decodes to part1 (stream not finished).
  let prefix : Array[Byte] = []
  for i in 0..<p1 {
    prefix.push(obuf[i])
  }
  let inf = @flate.Inflater::new()
  let dbuf = FixedArray::make(4096, b'\x00')
  let dst = inf.step(Bytes::from_array(prefix)[:], dbuf.mut_view())
  let _dc = inf.last_consumed()
  let dp = inf.last_produced()
  assert_true(dst is NeedMoreInput)
  let got : Array[Byte] = []
  for i in 0..<dp {
    got.push(dbuf[i])
  }
  assert_eq(Bytes::from_array(got), part1)
  // Continue past the flush point and finish; the whole stream round-trips.
  let out = Buffer()
  for i in 0..<p1 {
    out.write_byte(obuf[i])
  }
  let mut sent_end = false
  for ;; {
    let chunk = if sent_end { b""[:] } else { part2[:] }
    let st = enc.step(chunk, obuf.mut_view(), action=Finish)
    let _c = enc.last_consumed()
    let p = enc.last_produced()
    sent_end = true
    for i in 0..<p {
      out.write_byte(obuf[i])
    }
    if st is Done {
      break
    }
  }
  let full : Array[Byte] = []
  for b in part1 {
    full.push(b)
  }
  for b in part2 {
    full.push(b)
  }
  assert_eq(@flate.inflate_all(out.to_bytes()), Bytes::from_array(full))
}

///|
/// A one-shot flush request can arrive while an earlier block is still waiting
/// for output space. It must remain pending even when later drain calls no
/// longer pass `action=SyncFlush`.
test "Deflater latches sync flush across output backpressure" {
  // Exactly one internal high-water window: the whole view is accepted, then
  // its stored block is backpressured before the empty flush request arrives.
  let src = Bytes::from_array(Array::make(16642, b'\x5A'))
  let enc = @flate.Deflater::new(level=0)
  let no_output = FixedArray::make(0, b'\x00')
  let initial_status = enc.step(src[:], no_output.mut_view())
  let initial_consumed = enc.last_consumed()
  let initial_produced = enc.last_produced()
  assert_true(initial_status is NeedMoreOutput)
  assert_eq(initial_consumed, src.length())
  assert_eq(initial_produced, 0)
  let flush_status = enc.step(b""[:], no_output.mut_view(), action=SyncFlush)
  let flush_consumed = enc.last_consumed()
  let flush_produced = enc.last_produced()
  assert_true(flush_status is NeedMoreOutput)
  assert_eq(flush_consumed, 0)
  assert_eq(flush_produced, 0)
  let obuf = FixedArray::make(257, b'\x00')
  let prefix = Buffer()
  for ;; {
    let status = enc.step(b""[:], obuf.mut_view())
    let consumed = enc.last_consumed()
    let produced = enc.last_produced()
    assert_eq(consumed, 0)
    for i in 0..<produced {
      prefix.write_byte(obuf[i])
    }
    if status is NeedMoreInput {
      break
    }
    assert_true(status is NeedMoreOutput)
  }
  let flushed = prefix.to_bytes()
  assert_true(flushed.length() >= 4)
  assert_eq(flushed[flushed.length() - 4], b'\x00')
  assert_eq(flushed[flushed.length() - 3], b'\x00')
  assert_eq(flushed[flushed.length() - 2], b'\xFF')
  assert_eq(flushed[flushed.length() - 1], b'\xFF')
  let inf = @flate.Inflater::new()
  let decoded = FixedArray::make(18000, b'\x00')
  let decode_status = inf.step(flushed[:], decoded.mut_view())
  let decode_consumed = inf.last_consumed()
  let decode_produced = inf.last_produced()
  assert_true(decode_status is NeedMoreInput)
  assert_eq(decode_consumed, flushed.length())
  assert_eq(decode_produced, src.length())
  for i in 0..<src.length() {
    assert_eq(decoded[i], src[i])
  }
}

// ---- compression levels + reset ----

///|
/// Every level 0-9 produces a valid stream; level 0 is stored-only (no
/// compression), levels >= 1 compress the repetitive payload well.
test "compression levels round-trip" {
  let unit = b"level test payload, the quick brown fox jumps over. "
  let arr : Array[Byte] = []
  for _r in 0..<600 {
    for b in unit {
      arr.push(b)
    }
  }
  let src = Bytes::from_array(arr)
  for level in 0..<10 {
    let out = @flate.deflate_all(src, level~)
    assert_eq(@flate.inflate_all(out), src)
    if level == 0 {
      assert_true(out.length() >= src.length()) // stored only, framing added
    } else {
      assert_true(out.length() < src.length() / 10) // repetitive data shrinks
    }
  }
}

///|
/// `reset()` reuses one engine across independent streams: the Deflater's
/// output matches a fresh compressor's, and the Inflater decodes a second
/// stream cleanly after the first.
test "reset reuses engines across streams" {
  let s1 = b"first stream payload, first stream payload"
  let s2 = b"second stream: completely different bytes!!"
  let d = @flate.Deflater::new()
  assert_eq(d.last_consumed(), 0)
  assert_eq(d.last_produced(), 0)
  let obuf = FixedArray::make(4096, b'\x00')
  let st1 = d.step(s1[:], obuf.mut_view(), action=Finish)
  assert_true(st1 is Done)
  d.reset()
  assert_eq(d.last_consumed(), 0)
  assert_eq(d.last_produced(), 0)
  let st2 = d.step(s2[:], obuf.mut_view(), action=Finish)
  let p2 = d.last_produced()
  assert_true(st2 is Done)
  let reused : Array[Byte] = []
  for i in 0..<p2 {
    reused.push(obuf[i])
  }
  assert_eq(Bytes::from_array(reused), @flate.deflate_all(s2))
  let inf = @flate.Inflater::new()
  assert_eq(inf.last_consumed(), 0)
  assert_eq(inf.last_produced(), 0)
  let dbuf = FixedArray::make(4096, b'\x00')
  let ist1 = inf.step(@flate.deflate_all(s1)[:], dbuf.mut_view())
  let ip1 = inf.last_produced()
  assert_true(ist1 is Done)
  let got1 : Array[Byte] = []
  for i in 0..<ip1 {
    got1.push(dbuf[i])
  }
  assert_eq(Bytes::from_array(got1), s1)
  let sentinel = FixedArray::make(4, b'\xA5')
  let done_status = inf.step(@flate.deflate_all(s2)[:], sentinel.mut_view())
  assert_true(done_status is Done)
  assert_eq(inf.last_consumed(), 0)
  assert_eq(inf.last_produced(), 0)
  for byte in sentinel {
    assert_eq(byte, b'\xA5')
  }
  inf.reset()
  assert_eq(inf.last_consumed(), 0)
  assert_eq(inf.last_produced(), 0)
  let ist2 = inf.step(@flate.deflate_all(s2)[:], dbuf.mut_view())
  let ip2 = inf.last_produced()
  assert_true(ist2 is Done)
  let got2 : Array[Byte] = []
  for i in 0..<ip2 {
    got2.push(dbuf[i])
  }
  assert_eq(Bytes::from_array(got2), s2)
}

///|
/// Preset dictionary on the raw engine: back-references reach into the
/// preloaded window, the stream is smaller than without the dictionary, and
/// decoding without it fails (distances reach before the stream start).
test "preset dictionary: raw deflate round-trip" {
  let dict = b"the quick brown fox jumps over the lazy dog"
  let msg = b"the quick brown fox jumps over the lazy dog, again and again!"
  let d = @flate.Deflater::new(dictionary=dict[:])
  let obuf = FixedArray::make(4096, b'\x00')
  let st = d.step(msg[:], obuf.mut_view(), action=Finish)
  let p = d.last_produced()
  assert_true(st is Done)
  let comp : Array[Byte] = []
  for i in 0..<p {
    comp.push(obuf[i])
  }
  let compressed = Bytes::from_array(comp)
  // The dictionary must actually pay: smaller than dictionary-less output.
  assert_true(compressed.length() < @flate.deflate_all(msg).length())
  // With the dictionary: decodes to the message.
  let inf = @flate.Inflater::new(dictionary=dict[:])
  let dbuf = FixedArray::make(4096, b'\x00')
  let ist = inf.step(compressed[:], dbuf.mut_view())
  let ip = inf.last_produced()
  assert_true(ist is Done)
  let got : Array[Byte] = []
  for i in 0..<ip {
    got.push(dbuf[i])
  }
  assert_eq(Bytes::from_array(got), msg)
  // Without the dictionary: a back-reference reaches before the stream start.
  let inf2 = @flate.Inflater::new()
  try {
    let _ = inf2.step(compressed[:], dbuf.mut_view())
  } catch {
    InflateError(_, _) => ()
  } noraise {
    _ => fail("expected the dictionary-less decode to fail")
  }
}

// ---- optimal (zopfli-style) parser + block planner ----

///|
/// The optimal path round-trips and is never worse than the default level on
/// compressible text (the unit embeds a lazy-matching trap: "abcde abcdef").
test "deflate_all_optimal round-trips and beats greedy" {
  let unit = b"optimal parsing pays where greedy grabs too early: abcde abcdef. "
  let arr : Array[Byte] = []
  for _r in 0..<120 {
    for b in unit {
      arr.push(b)
    }
  }
  let src = Bytes::from_array(arr)
  let opt = @flate.deflate_all_optimal(src, iterations=8)
  assert_eq(@flate.inflate_all(opt), src)
  assert_true(opt.length() <= @flate.deflate_all(src).length())
}

///|
/// Heterogeneous input (compressible text, then pseudo-random bytes): the
/// content-driven splitter plus per-block stored/fixed/dynamic choice keeps
/// the optimal path at least as good as the leveled encoder.
test "deflate_all_optimal splits heterogeneous data" {
  let arr : Array[Byte] = []
  let text = b"a stretch of plain compressible text, over and over again. "
  for _r in 0..<80 {
    for b in text {
      arr.push(b)
    }
  }
  let mut x = 0xDEADBEEFU
  for _i in 0..<4800 {
    x = x ^ (x << 13)
    x = x ^ (x >> 17)
    x = x ^ (x << 5)
    arr.push((x & 0xFF).reinterpret_as_int().to_byte())
  }
  let src = Bytes::from_array(arr)
  let opt = @flate.deflate_all_optimal(src, iterations=5)
  assert_eq(@flate.inflate_all(opt), src)
  assert_true(opt.length() <= @flate.deflate_all(src, level=9).length() + 16)
}

///|
test "deflate_all_optimal: empty and tiny inputs" {
  assert_eq(@flate.inflate_all(@flate.deflate_all_optimal(b"")), b"")
  assert_eq(@flate.inflate_all(@flate.deflate_all_optimal(b"x")), b"x")
  assert_eq(
    @flate.inflate_all(@flate.deflate_all_optimal(b"aaaaaaaa")),
    b"aaaaaaaa",
  )
}
